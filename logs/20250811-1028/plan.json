{
  "target": "prod",
  "steps": [
    {
      "name": "deploy",
      "commands": [
        "ssh -p 22 -i ~/.ssh/id_ed25519 ubuntu@your.server.com 'cd /home/ubuntu/strapi && git pull --ff-only || true'",
        "ssh -p 22 -i ~/.ssh/id_ed25519 ubuntu@your.server.com 'cd /home/ubuntu/strapi && pnpm build'",
        "ssh -p 22 -i ~/.ssh/id_ed25519 ubuntu@your.server.com 'cd /home/ubuntu/strapi && pm2 reload strapi-frontend'"
      ],
      "status": "planned"
    },
    {
      "name": "invalidate",
      "commands": [
        "POST https://minokamo.xyz/api/revalidate?secret=***slug\":\"/hello-strapi\"}"
      ],
      "status": "planned"
    },
    {
      "name": "healthcheck",
      "commands": [
        "curl -sS -o /dev/null -w '%{http_code}' http://127.0.0.1:3000/",
        "curl -sS -o /dev/null -w '%{http_code}' http://127.0.0.1:3000/sitemap.xml"
      ],
      "status": "planned"
    }
  ]
}